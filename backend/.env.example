# Server Configuration
HOST=127.0.0.1
PORT=8000
DEBUG=True

# Database Configuration
# Fallback to local SQLite if not specified. On Render, this will be populated automatically by render.yaml blueprint mapping.
# For MySQL: mysql+pymysql://user:password@host:port/database
# For PostgreSQL: postgresql://user:password@host:port/database
DATABASE_URL=sqlite:///./dataset_analysis.db

# JWT & Authentication Settings
# Generate a cryptographically secure key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS Configuration
# Comma-separated list of allowed origins. Exclude spaces.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:3000,http://127.0.0.1:3000
